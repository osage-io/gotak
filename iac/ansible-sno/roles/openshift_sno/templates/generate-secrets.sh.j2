#!/usr/bin/env bash
# Generate the CCO-Manual operator credential Secret manifests using this
# node's instance-profile credentials (fetched from IMDSv2).
# Usage: generate-operator-secrets <output-dir>
set -euo pipefail

OUT="${1:?usage: generate-operator-secrets <output-dir>}"
mkdir -p "$OUT"

TOKEN=$(curl -sX PUT http://169.254.169.254/latest/api/token \
  -H 'X-aws-ec2-metadata-token-ttl-seconds: 900')
ROLE=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/iam/security-credentials/)
CREDS=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" \
  "http://169.254.169.254/latest/meta-data/iam/security-credentials/${ROLE}")

AKI=$(echo "$CREDS" | jq -r .AccessKeyId)
SAK=$(echo "$CREDS" | jq -r .SecretAccessKey)
TOK=$(echo "$CREDS" | jq -r .Token)

write_secret() {
  ns="$1"; name="$2"
  cat > "${OUT}/99_secret_${ns}_${name}.yaml" <<YAML
apiVersion: v1
kind: Secret
metadata:
  namespace: ${ns}
  name: ${name}
type: Opaque
stringData:
  aws_access_key_id: ${AKI}
  aws_secret_access_key: ${SAK}
  credentials: |
    [default]
    aws_access_key_id = ${AKI}
    aws_secret_access_key = ${SAK}
    aws_session_token = ${TOK}
YAML
  echo "wrote ${OUT}/99_secret_${ns}_${name}.yaml"
}

{% for s in operator_secrets %}
write_secret "{{ s.namespace }}" "{{ s.name }}"
{% endfor %}
