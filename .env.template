# GOTAK Military Operations Management System
# Environment variables template
# Copy this file to .env and fill in the actual values

# Application settings
GOTAK_ENV=development
GOTAK_DEBUG=true

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gotak
DB_USER=gotak_user
DB_PASSWORD=your_secure_password_here

# Security settings
SECRET_KEY=your_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here

# External service APIs
INTEL_API_KEY=your_intel_api_key_here
COMMS_API_KEY=your_comms_api_key_here

# Operational settings
MAX_CLASSIFICATION_LEVEL=RESTRICTED
AUDIT_ENDPOINT=your_audit_endpoint_here

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/gotak/gotak.log

# Network settings
BIND_HOST=0.0.0.0
BIND_PORT=8080
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem
