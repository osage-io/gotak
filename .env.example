# GoTAK Production Environment Variables
# Copy this file to .env and update with your values

# Version Information
VERSION=latest
BUILD_TIME=
GIT_COMMIT=

# Database Configuration
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=gotak
POSTGRES_USER=gotak

# Redis Configuration
REDIS_PASSWORD=changeme_redis_password_here

# Application Security
JWT_SECRET=changeme_use_long_random_string_here
GIN_MODE=release

# Logging
LOG_LEVEL=info

# Map Configuration (optional)
MAP_LAT=38.9072
MAP_LNG=-77.0369
MAP_ZOOM=12

# TLS/SSL (for production)
TLS_CERT_PATH=/app/certs/server.crt
TLS_KEY_PATH=/app/certs/server.key
TLS_ENABLED=true

# External URLs (for production deployment)
EXTERNAL_URL=https://your-domain.com
API_URL=https://your-domain.com:8080
WS_URL=wss://your-domain.com:8087/ws