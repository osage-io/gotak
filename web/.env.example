# GoTAK Web Application Environment Variables

# Server Configuration
VITE_GOTAK_SERVER_URL=http://localhost:8080
VITE_SERVER_VERSION=1.0.0

# AI Intelligence Officer Configuration
# Get your API key from https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Model Configuration (optional - defaults shown)
VITE_AI_MODEL=claude-3-sonnet-20240229
VITE_AI_MAX_TOKENS=1000

# Feature Flags
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_ENCRYPTION=false